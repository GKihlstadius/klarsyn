# LLM-provider: "anthropic" (skarpt) eller "openai-compatible" (Groq/Gemini, gratis dev)
LLM_PROVIDER=anthropic

# Anthropic (skarpt lage)
ANTHROPIC_API_KEY=
INTERVIEW_MODEL=claude-sonnet-5
REPORT_MODEL=claude-opus-4-8

# OpenAI-kompatibel provider (Groq: https://api.groq.com/openai/v1)
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_API_KEY=
# INTERVIEW_MODEL=llama-3.3-70b-versatile

# Databas (Supabase Postgres). Hamtas i Supabase: Project Settings > Database > Connection string > URI
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres

# Server
PORT=3001

# Frontend (produktion): backend-URL. Tom lokalt (Vite-proxy skoter det).
# VITE_API_URL=https://klarsyn-backend.onrender.com

# Admin-login (demo, byt i produktion)
ADMIN_USER=test123
ADMIN_PASS=test123
ADMIN_TOKEN=klarsyn-demo-token
